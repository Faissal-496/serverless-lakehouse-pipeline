# Copy this file to terraform.tfvars and fill in the values.
# Sensitive values (passwords, keys) should not be committed.

aws_region   = "eu-west-3"
environment  = "prod"
project_name = "lakehouse-assurance"

s3_bucket_name = "lakehouse-assurance-moto-prod"

# RDS
rds_master_username = "lakehouse_admin"
rds_master_password = "CHANGE_ME"

# Amazon MQ
mq_username = "airflow"
mq_password = "CHANGE_ME"

# Jenkins
jenkins_admin_user     = "admin"
jenkins_admin_password = "CHANGE_ME"

# Airflow secrets (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
airflow_fernet_key           = "CHANGE_ME"
airflow_webserver_secret_key = "CHANGE_ME"

# ACM certificate ARN (must be validated for octaa.tech and *.octaa.tech)
alb_certificate_arn = "arn:aws:acm:eu-west-3:123456789012:certificate/CHANGE_ME"

# CloudWatch
cloudwatch_alarm_email = "alerts@octaa.tech"

# ECR repositories
ecr_repository_names = ["airflow-runtime"]
