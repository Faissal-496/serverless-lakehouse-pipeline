
# ============================================================================
# ENV TEMPLATE - COPY TO .env AND FILL VALUES
# ============================================================================

# Environment Setup
APP_ENV=dev
GIT_SYNC_REPO=https://github.com/Faissal-496/serverless-lakehouse-pipeline.git
GIT_SYNC_BRANCH=main

# ============================================================================
# SPARK CLUSTER SELECTOR  -  THE KEY SWITCH BETWEEN LOCAL AND EMR
# ============================================================================
# Local Docker standalone cluster:
#   SPARK_MASTER=spark://spark-master:7077
#   SPARK_DEPLOY_MODE=client
#   APP_ENV=prod
#
# AWS EMR Serverless / EMR on EC2:
#   SPARK_MASTER=yarn
#   SPARK_DEPLOY_MODE=cluster
#   APP_ENV=emr
#
# These two variables override the defaults in config/spark/prod.yaml
# (or config/spark/emr.yaml when APP_ENV=emr).
# No code change is required when switching environments.
SPARK_MASTER=spark://spark-master:7077
SPARK_DEPLOY_MODE=client

# AWS Credentials (never commit real values)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-west-3
AWS_ACCOUNT_ID=123456789012

# AWS S3 Configuration
S3_BUCKET=your-bucket-name
S3_DATA_PATH=s3a://${S3_BUCKET}/RAW
S3_BRONZE_PATH=s3a://${S3_BUCKET}/bronze
S3_SILVER_PATH=s3a://${S3_BUCKET}/silver
S3_GOLD_PATH=s3a://${S3_BUCKET}/gold
S3_LOGS_PATH=s3a://${S3_BUCKET}/logs
S3_CONFIG_PATH=s3a://${S3_BUCKET}/config
S3_ARCHIVE_PATH=s3a://${S3_BUCKET}/archive

# CloudWatch Configuration
CLOUDWATCH_ENABLED=true
CLOUDWATCH_LOG_GROUP_SPARK=/aws/lakehouse/spark
CLOUDWATCH_LOG_GROUP_AIRFLOW=/aws/lakehouse/airflow
CLOUDWATCH_LOG_RETENTION_DAYS=90

# Secrets Manager
SECRETS_MANAGER_ENABLED=false
SECRETS_MANAGER_KEY=lakehouse/rds/prod

# Glue Configuration
GLUE_ENABLED=true
GLUE_DATABASE=your_glue_database
GLUE_DB_NAME=your_glue_database

# Athena Configuration
ATHENA_ENABLED=true
ATHENA_DATABASE=lakehouse
ATHENA_OUTPUT_LOCATION=s3a://${S3_BUCKET}/athena/results/

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Spark Configuration
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_SHUFFLE_PARTS=4
SPARK_LOG_LEVEL=WARN
CONFIG_DIR=/opt/lakehouse/config
DATA_BASE_PATH=/opt/lakehouse/data

# S3 Logs (used by application config)
S3_LOGS_BUCKET=${S3_BUCKET}
S3_LOGS_PREFIX=logs/lakehouse
ENABLE_S3_LOGS=true

# ============================================================================
# AIRFLOW CONFIGURATION
# ============================================================================

# RDS PostgreSQL Configuration
RDS_ENDPOINT=your-rds-endpoint
RDS_PORT=5432
DB_NAME=lakehouse_prod
DB_USER=lakehouse_admin
DB_PASSWORD=change-me

# Airflow Runtime (required for docker/compose/docker-compose-aws.yml)
AIRFLOW_IMAGE=
AIRFLOW_DB_CONN=
AIRFLOW_RESULT_BACKEND=
AIRFLOW_BROKER_URL=
AIRFLOW_FERNET_KEY=change-me-fernet
AIRFLOW_WEBSERVER_SECRET_KEY=change-me-webserver

# EMR Serverless (Airflow -> EMR)
EMR_SERVERLESS_APPLICATION_ID=
EMR_SERVERLESS_EXECUTION_ROLE_ARN=
EMR_SERVERLESS_S3_ENTRYPOINT=
EMR_SERVERLESS_LOG_URI=s3a://${S3_BUCKET}/emr-serverless/logs

# Lakehouse Airflow Variables
AIRFLOW__VAR__LAKEHOUSE_ENV=prod
AIRFLOW__VAR__LAKEHOUSE_S3_BUCKET=your-bucket-name
AIRFLOW__VAR__LAKEHOUSE_GLUE_DB=your_database
AIRFLOW__VAR__ALERT_EMAIL=data-platform@company.com
